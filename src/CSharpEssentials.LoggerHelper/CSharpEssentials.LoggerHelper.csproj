<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <PackageOutputPath>C:\Nuget</PackageOutputPath>
    <Title>CSharpEssentials.LoggerHelper — Route Serilog sinks by level with zero code</Title>
    <Authors>Alessandro Chiodo</Authors>
    <Description>Stop wiring Serilog by hand. Add 3 lines of JSON and every ILogger&lt;T&gt; routes logs where they belong — errors to Email, info to Console, traces to Seq. 9 sinks, zero boilerplate. New in 5.0.8: declarative sensitive-data masking enricher redacts emails, credit cards, JWT/Bearer tokens and connection-string passwords from every sink at once — one JSON block, zero code changes.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>CSharpEssentials.png</PackageIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\img\CSharpEssentials.png" Pack="true" PackagePath="\" />
  </ItemGroup>

  <PropertyGroup>
    <RepositoryType>git</RepositoryType>
    <PackageTags>serilog;structured-logging;log-routing;multi-sink;logging;dotnet;aspnetcore;log-level-routing;ilogger;opentelemetry;observability;middleware;data-masking;pii-redaction;sensitive-data;console-sink;file-sink;email-sink;telegram-sink;elasticsearch-sink;postgresql-sink;mssql-sink;seq-sink</PackageTags>
    <RepositoryUrl>https://github.com/alexbypa/CSharp.Essentials</RepositoryUrl>
    <PackageProjectUrl>https://www.loggerhelper.com</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="CSharpEssentials.LoggerHelper.Tests" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Serilog" Version="4.2.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net6.0'">
    <PackageReference Include="Serilog.Settings.Configuration" Version="3.4.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="9.0.17" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="6.0.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' != 'net6.0'">
    <PackageReference Include="Serilog.Settings.Configuration" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="9.0.1" />
  </ItemGroup>

</Project>
