<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <PackageOutputPath>C:\Nuget</PackageOutputPath>
    <Title>LoggerHelper File Sink — JSON rolling file logs with per-level routing</Title>
    <Authors>Alessandro Chiodo</Authors>
    <Description>Persist structured logs to rolling JSON files with zero configuration. One JSON entry routes the exact log levels you care about to file. New in 5.0.7: TryGetValue fast path in multi-tenant DynamicPropertyFileSink — 3-4x faster on steady-state hits, zero delegate allocations. Supports FileNameProperty for per-tenant log separation: different tenants write to different files automatically.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://www.loggerhelper.it</PackageProjectUrl>
    <PackageIcon>CSharpEssentials.png</PackageIcon>
    <PackageTags>serilog;logging;file;rolling-file;sink;structured-logging;loggerhelper;json-logs;ilogger;multi-tenant;dynamic-routing;aspnetcore;dotnet8;dotnet9;dotnet10</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\..\img\CSharpEssentials.png" Pack="true" PackagePath="\" />
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\CSharpEssentials.LoggerHelper\CSharpEssentials.LoggerHelper.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="10.0.9" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.0.0" />
  </ItemGroup>
</Project>
