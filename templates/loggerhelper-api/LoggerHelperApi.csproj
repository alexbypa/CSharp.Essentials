<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CSharpEssentials.LoggerHelper" Version="5.0.0" />
    <PackageReference Include="CSharpEssentials.LoggerHelper.Sink.Console" Version="5.0.0" />
    <PackageReference Include="CSharpEssentials.LoggerHelper.Sink.File" Version="5.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="appsettings.LoggerHelper.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
