{
  "LoggerHelper": {
    "ApplicationName": "LoggerHelperApi",
    "Routes": [
      { "Sink": "Console", "Levels": ["Information", "Warning", "Error", "Fatal"] },
      { "Sink": "File", "Levels": ["Information", "Warning", "Error", "Fatal"] }
    ],
    "Sinks": {
      "File": { "Path": "Logs", "RollingInterval": "Day" }
    },
    "General": {
      "EnableRequestResponseLogging": true
    }
  }
}
